# ============================================================
# MongoDB Authentication Configuration
# ============================================================
# This file contains MongoDB authentication settings for the ReZ ecosystem.
# Copy this file to .env in the repo root and fill in values.
# ============================================================
#
# Generate credentials:
#   Root password:    openssl rand -base64 24
#   Service password: openssl rand -base64 32
# ============================================================

# ── MongoDB Root User [REQUIRED] ─────────────────────────
# This is the admin user that can create other users and manage MongoDB
# Generate with: openssl rand -base64 24
MONGO_ROOT_USERNAME=rez_admin
MONGO_ROOT_PASSWORD=change-me-generate-with-openssl-rand-base64-24

# ── MongoDB Service User Password [REQUIRED] ───────────────
# All 16 services use this same password for their individual database users
# Generate with: openssl rand -base64 32
MONGO_SERVICE_PASSWORD=change-me-generate-with-openssl-rand-base64-32

# ── MongoDB Connection Settings ─────────────────────────────

# Auth source - database where users are defined (usually 'admin')
MONGODB_AUTH_SOURCE=admin

# Replica set name (must match docker-compose.yml)
MONGODB_REPLICA_SET=rs0

# Read preference options:
#   primary            - Default, all reads go to primary
#   secondary         - All reads go to secondaries (for analytics/reporting)
#   primaryPreferred   - Prefer primary, fall back to secondary
#   secondaryPreferred - Prefer secondary, fall back to primary
#   nearest           - Read from nearest replica set member
MONGODB_READ_PREFERENCE=primary

# ── Connection String Format ────────────────────────────────
#
# Local Development (Docker Compose):
#   mongodb://<user>:<password>@mongodb-primary:27017,mongodb-secondary-1:27017,mongodb-secondary-2:27017/<database>?authSource=admin&replicaSet=rs0
#
# Production (MongoDB Atlas):
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?authSource=admin&replicaSet=<replica-set>&w=majority
#
# Single Node (Development only):
#   mongodb://<user>:<password>@localhost:27017/<database>?authSource=admin

# ── Service Database Mapping ────────────────────────────────
# Each service has its own database and user

# Service: rez-auth-service
# Database: rez_auth
# User: rez_auth_user
# Connection: mongodb://rez_auth_user:${MONGO_SERVICE_PASSWORD}@localhost:27017/rez_auth?authSource=admin
MONGO_AUTH_DB=rez_auth
MONGO_AUTH_USER=rez_auth_user

# Service: rez-wallet-service
# Database: rez_wallet
# User: rez_wallet_user
